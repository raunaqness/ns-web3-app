# .env — local development secrets
# Copy this to .env and fill in real values. Never commit .env to git.

SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Ethereum RPC provider URL (Infura / Alchemy / etc.)
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# PostgreSQL — leave blank to use SQLite for local dev
# DATABASE_URL=postgres://user:password@localhost:5432/ens_social
